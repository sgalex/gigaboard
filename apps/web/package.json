{
    "name": "gigaboard-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "npm run copy-libs && vite build",
        "build:check": "npm run copy-libs && tsc -b && vite build",
        "preview": "vite preview",
        "copy-libs": "node -e \"const fs=require('fs'); fs.cpSync('../../node_modules/echarts/dist/echarts.min.js','public/libs/echarts.min.js',{recursive:true}); fs.mkdirSync('public/libs/fonts',{recursive:true}); ['inter-latin-wght-normal','inter-latin-ext-wght-normal','inter-cyrillic-wght-normal','inter-cyrillic-ext-wght-normal'].forEach(f=>fs.cpSync('../../node_modules/@fontsource-variable/inter/files/'+f+'.woff2','public/libs/fonts/'+f+'.woff2'));\""
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@tanstack/react-query": "^5.51.9",
        "@xyflow/react": "^12.10.0",
        "autoprefixer": "^10.4.23",
        "axios": "^1.13.2",
        "date-fns": "^4.1.0",
        "echarts": "^6.0.0",
        "modern-screenshot": "^4.6.8",
        "postcss": "^8.5.6",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^6.23.0",
        "reactflow": "^11.11.0",
        "recharts": "^3.7.0",
        "remark-gfm": "^4.0.1",
        "socket.io-client": "^4.8.3",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.18",
        "xlsx": "^0.18.5",
        "zustand": "^4.5.2"
    },
    "devDependencies": {
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-form": "^0.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@tailwindcss/postcss": "^4.1.18",
        "@types/react": "^18.2.24",
        "@types/react-dom": "^18.2.8",
        "@types/xlsx": "^0.0.35",
        "@vitejs/plugin-react": "^4.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.563.0",
        "typescript": "^5.6.3",
        "vite": "^5.0.0"
    }
}
