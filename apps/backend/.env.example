# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gigaboard_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# GigaChat (for AI features)
GIGACHAT_API_KEY=your-gigachat-api-key
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.7
GIGACHAT_MAX_TOKENS=2048
GIGACHAT_VERIFY_SSL=False
GIGACHAT_SCOPE=GIGACHAT_API_CORP

# Environment
ENVIRONMENT=development
