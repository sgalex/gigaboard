# =============================================================================
# GigaBoard — переменные окружения (корень репозитория)
# =============================================================================
# Скопируйте в `.env` и заполните. Файл в репозиторий не коммитить.
#
# Backend загружает ТОЛЬКО корень: `.env`, затем (если есть) `.env.local`
# с переопределениями. `apps/backend/.env` не используется.
#
# Frontend (Vite): префикс VITE_* читает Vite из каталога `apps/web/`
# (файлы `apps/web/.env`, `apps/web/.env.local`). См. раздел ниже.
# =============================================================================

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+asyncpg://gigaboard:gigaboard_secret@localhost:5432/gigaboard
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Windows / нестабильный пул: 1, true, yes — новое соединение на запрос (NullPool)
#DB_USE_NULL_POOL=

# ============================================
# Redis
# ============================================
# DB 0 — основной клиент; Message Bus подставляет отдельный номер DB из URL (см. redis_config)
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5

# ============================================
# JWT
# ============================================
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars-random
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# HTTP / CORS
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# Разрешённые Origin для браузера (через запятую, без пробелов или с trim).
# По умолчанию в коде уже есть localhost:5173/3000 и http://localhost / 127.0.0.1.
#CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1

# ============================================
# Admin (опционально)
# ============================================
# Если заданы оба — при старте создаётся/обновляется пользователь с role=admin.
# Вход: обычная страница логина с этим email и паролем.
#ADMIN_EMAIL=admin@gigaboard.local
#ADMIN_PASSWORD=

# LLM и GigaChat задаются только в интерфейсе приложения (профиль пользователя и
# системные пресеты для администратора). См. docs/ADMIN_AND_SYSTEM_LLM.md.

# ============================================
# Хранение файлов
# ============================================
# database — в БД (по умолчанию); local — файловая система; s3 — объектное хранилище
STORAGE_BACKEND=database
# При STORAGE_BACKEND=local — каталог относительно процесса backend
STORAGE_LOCAL_PATH=data/uploads
STORAGE_MAX_FILE_SIZE_MB=100

# S3 / MinIO / совместимые (при STORAGE_BACKEND=s3)
#S3_ENDPOINT_URL=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
S3_BUCKET_NAME=gigaboard-uploads
S3_REGION=us-east-1

# ============================================
# Окружение приложения
# ============================================
ENVIRONMENT=development

# ============================================
# Multi-Agent (отладка)
# ============================================
# Запись трейсов оркестратора в JSONL (по умолчанию включено: true)
#MULTI_AGENT_TRACE_ENABLED=true
# Каталог для трейсов (пусто — дефолт внутри apps/backend/logs/...)
#MULTI_AGENT_TRACE_DIR=

# ============================================
# Docker Compose (хост / подстановки в compose)
# ============================================
# Используются docker-compose.yml, не читаются Settings напрямую, если не проброшены в сервис.
#POSTGRES_USER=gigaboard
#POSTGRES_PASSWORD=gigaboard_secret
#POSTGRES_DB=gigaboard
#POSTGRES_PORT=5432
#REDIS_PORT=6379
# Если на хосте уже занят 6379 (локальный Redis) — например 6380
#REDIS_PORT=6380
#BACKEND_PORT=8000
#FRONTEND_PORT=80
#FRONTEND_DEV_PORT=5173
# Сборка backend: если из Docker VM недоступен pypi.org — зеркало для build-arg
#PYPI_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# 1 — не выполнять alembic upgrade при старте backend-контейнера
#SKIP_ALEMBIC_UPGRADE=0

# ============================================
# Frontend (Vite) — файл apps/web/.env или apps/web/.env.local
# ============================================
# Базовый URL API и Socket.IO (production build, отдельный домен и т.п.)
#VITE_API_URL=http://localhost:8000
#
# Только dev + docker-compose.dev: прокси в vite.config.ts (на хосте не нужно)
#VITE_DEV_PROXY_TARGET=http://backend:8000
