# GigaBoard Backend Configuration
# Copy to .env and configure for your environment

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gigaboard
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=your-secret-key-change-in-production-use-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Server
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# ============================================
# GigaChat AI
# ============================================
GIGACHAT_API_KEY=your_gigachat_api_key
GIGACHAT_MODEL=GigaChat-Max
GIGACHAT_TEMPERATURE=0.7
GIGACHAT_MAX_TOKENS=2048
GIGACHAT_VERIFY_SSL=False
GIGACHAT_SCOPE=GIGACHAT_API_CORP

# ============================================
# File Storage
# ============================================
# Backend: 'local' (filesystem) or 's3' (AWS S3, MinIO, Yandex Object Storage)
STORAGE_BACKEND=local

# Local Storage (when STORAGE_BACKEND=local)
STORAGE_LOCAL_PATH=data/uploads
STORAGE_MAX_FILE_SIZE_MB=100

# S3 Storage (when STORAGE_BACKEND=s3)
# Leave S3_ENDPOINT_URL empty for AWS S3, or set for MinIO/compatible
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=gigaboard-uploads
S3_REGION=us-east-1

# ============================================
# Environment
# ============================================
ENVIRONMENT=development
