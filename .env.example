# =============================================================================
# GigaBoard — переменные окружения (корень репозитория)
# =============================================================================
# Скопируйте в `.env` и заполните. Файл в репозиторий не коммитить.
#
# Backend загружает ТОЛЬКО корень: `.env`, затем (если есть) `.env.local`
# с переопределениями. `apps/backend/.env` не используется.
#
# Frontend (Vite): префикс VITE_* читает Vite из каталога `apps/web/`
# (файлы `apps/web/.env`, `apps/web/.env.local`). См. раздел ниже.
# =============================================================================

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql+asyncpg://gigaboard:gigaboard_secret@localhost:5432/gigaboard
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Windows / нестабильный пул: 1, true, yes — новое соединение на запрос (NullPool)
#DB_USE_NULL_POOL=

# ============================================
# Redis
# ============================================
# DB 0 — основной клиент; Message Bus подставляет отдельный номер DB из URL (см. redis_config)
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5

# ============================================
# JWT
# ============================================
JWT_SECRET_KEY=your-secret-key-change-in-production-min-32-chars-random
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# HTTP / CORS
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# Разрешённые Origin для браузера (через запятую, без пробелов или с trim).
# В Docker задайте оба варианта хоста, если открываете UI и как http://localhost:3000, и как http://127.0.0.1:3000:
#CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ============================================
# Admin (опционально)
# ============================================
# Если заданы оба — при старте создаётся/обновляется пользователь с role=admin.
# Вход: обычная страница логина с этим email и паролем.
#ADMIN_EMAIL=admin@gigaboard.local
#ADMIN_PASSWORD=

# LLM и GigaChat задаются только в интерфейсе приложения (профиль пользователя и
# системные пресеты для администратора). См. docs/ADMIN_AND_SYSTEM_LLM.md.

# ============================================
# Хранение файлов
# ============================================
# database — в БД (по умолчанию); local — файловая система; s3 — объектное хранилище
STORAGE_BACKEND=database
# При STORAGE_BACKEND=local — каталог относительно процесса backend
STORAGE_LOCAL_PATH=data/uploads
STORAGE_MAX_FILE_SIZE_MB=100

# S3 / MinIO / совместимые (при STORAGE_BACKEND=s3)
#S3_ENDPOINT_URL=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
S3_BUCKET_NAME=gigaboard-uploads
S3_REGION=us-east-1

# ============================================
# Окружение приложения
# ============================================
ENVIRONMENT=development

# ============================================
# Multi-Agent (отладка)
# ============================================
# Персональные переопределения (только admin): Профиль → «Multi-Agent» (user_ai_settings.multi_agent_settings).
# Приоритет: UI пользователя → эти переменные окружения → дефолты в коде.
# Запись трейсов оркестратора в JSONL (включено)
MULTI_AGENT_TRACE_ENABLED=true
# Каталог для трейсов (пусто — дефолт внутри apps/backend/logs/...)
#MULTI_AGENT_TRACE_DIR=
# Ответы тулов в JSONL: полный дамп в details.result (см. orchestrator tool_result)
#MULTI_AGENT_TRACE_TOOL_DATA_MAX_LIST_ITEMS=200
#MULTI_AGENT_TRACE_TOOL_DATA_MAX_CHARS=200000
# 0 = без лимита по символам (осторожно при огромных таблицах)
# Превью содержимого таблиц в JSONL (events[].details.tables_content_preview, structurizer_tables_snapshot)
#MULTI_AGENT_TRACE_TABLE_CONTENTS=true
# Добавлять превью таблиц для всех task_type, не только document_extraction (осторожно: большие логи)
#MULTI_AGENT_TRACE_TABLE_CONTENTS_ALL=false
#MULTI_AGENT_TRACE_TABLE_CONTENTS_MAX_TABLES=8
#MULTI_AGENT_TRACE_TABLE_CONTENTS_MAX_ROWS=40
#MULTI_AGENT_TRACE_TABLE_CONTENTS_MAX_CELL_CHARS=600
# Снимок результатов агентов (narrative, таблицы, findings, plan, validation, tool_requests…):
# events[].details.agent_result_data и в конце файла trace_payload.results_snapshot.
# При false — только счётчики и (если включено выше) structurizer_tables_snapshot без полного дампа.
#MULTI_AGENT_TRACE_AGENT_RESULT_DATA=true
#MULTI_AGENT_TRACE_NARRATIVE_MAX_CHARS=16000
#MULTI_AGENT_TRACE_FINDINGS_MAX=80
#MULTI_AGENT_TRACE_SOURCES_MAX=30
#MULTI_AGENT_TRACE_SOURCE_SNIPPET_CHARS=800
#MULTI_AGENT_TRACE_CODE_BLOCKS_MAX=12
#MULTI_AGENT_TRACE_CODE_MAX_CHARS=48000
#MULTI_AGENT_TRACE_METADATA_MAX_CHARS=12000
#MULTI_AGENT_TRACE_RAW_RESULT_MAX_CHARS=100000
#MULTI_AGENT_TRACE_TOOL_RESULT_DATA_MAX_CHARS=12000
# readTableData / readTableListFromContentNodes: использовать _compute_filtered_pipeline (как UI доски/дашборда; см. docs/MULTI_AGENT.md, docs/CROSS_FILTER_SYSTEM.md §3.5)
#MULTI_AGENT_TOOLS_USE_FILTERED_PIPELINE=true
# Макс. раундов tool loop на один шаг агента (дефолт и минимум в коде 15; значения <15 поднимаются до 15)
#MULTI_AGENT_TOOL_MAX_ROUNDS_PER_STEP=15
# Analyst: макс. число tool_requests за один раунд (дедуп по tool+args; снижает зацикливание readTableData)
#MULTI_AGENT_ANALYST_MAX_TOOL_REQUESTS_PER_ROUND=2
# Макс. попыток replan при validation recovery (отдельно от общего лимита replan)
#MULTI_AGENT_MAX_VALIDATION_RECOVERY=2
# Structurizer: единый лимит символов входа в user-промпт (после — усечение)
#MULTI_AGENT_STRUCTURIZER_MAX_CONTENT_CHARS=20000
# Structurizer + Research Chat: суммарный лимит (текст страниц + DISCOVERED_RESOURCES; URL не маскируются)
#MULTI_AGENT_STRUCTURIZER_RESEARCH_MAX_TOTAL_CHARS=52000
# Structurizer + Research Chat: лимит текста на одну страницу из research
#MULTI_AGENT_STRUCTURIZER_RESEARCH_MAX_PER_SOURCE_CHARS=2800
# Structurizer + Research Chat: лимит user-промпта после сборки (обычно = RESEARCH_MAX_TOTAL_CHARS)
#MULTI_AGENT_STRUCTURIZER_RESEARCH_MAX_LLM_CONTENT_CHARS=52000
# Structurizer + Research Chat: max_tokens ответа LLM (больше строк в JSON)
#MULTI_AGENT_STRUCTURIZER_RESEARCH_MAX_TOKENS=5500
# ResearchAgent: число волн загрузки (1 = только URL из Discovery; для Research Chat с controller=research дефолт 3)
#MULTI_AGENT_RESEARCH_CRAWL_MAX_DEPTH=3
# ResearchAgent: макс. страниц за один запуск (волновой обход)
#MULTI_AGENT_RESEARCH_MAX_TOTAL_PAGES=30
# ResearchAgent: макс. URL на волну после отбора LLM
#MULTI_AGENT_RESEARCH_CRAWL_MAX_URLS_PER_WAVE=8
# ResearchAgent: макс. кандидатов ссылок в промпт LLM на волну (после ранжирования по релевантности)
#MULTI_AGENT_RESEARCH_CRAWL_MAX_LLM_CANDIDATES=40
# ResearchAgent: макс. уникальных ссылок, собранных со всех страниц волны перед сортировкой и отбором в LLM
#MULTI_AGENT_RESEARCH_CRAWL_RAW_CANDIDATES_MAX=200
# ResearchAgent: discovered_resources — проверка доступности embedded URL перед добавлением в каталог (HEAD / GET Range)
#MULTI_AGENT_RESEARCH_DISCOVERED_RESOURCE_PROBE_ENABLED=true
#MULTI_AGENT_RESEARCH_DISCOVERED_RESOURCE_PROBE_TIMEOUT_SEC=5
#MULTI_AGENT_RESEARCH_DISCOVERED_RESOURCE_PROBE_CONCURRENCY=8
# ResearchAgent: после загрузки — отбор страниц по релевантности задаче (LLM, JSON keep_ids)
#MULTI_AGENT_RESEARCH_TASK_RELEVANCE_FILTER_ENABLED=true
# ResearchAgent: страниц в одном промпте к LLM (релевантность)
#MULTI_AGENT_RESEARCH_PAGE_RELEVANCE_LLM_BATCH_SIZE=12
# ResearchAgent: символов текста страницы в промпт LLM (релевантность)
#MULTI_AGENT_RESEARCH_PAGE_RELEVANCE_LLM_EXCERPT_CHARS=1600
#MULTI_AGENT_RESEARCH_PAGE_RELEVANCE_LLM_MAX_TOKENS=1200
#MULTI_AGENT_RESEARCH_PAGE_RELEVANCE_LLM_TEMPERATURE=0.12

# ============================================
# Docker Compose (хост / подстановки в compose)
# ============================================
# По умолчанию наружу публикуется только FRONTEND_PORT (nginx → /api, /socket.io, /docs).
# Postgres, Redis и backend доступны только внутри сети Compose.
# DATABASE_URL в этом файле — для локального backend на хосте; в контейнере backend берёт URL из docker-compose (хост postgres).
# В compose задано GIGABOARD_IN_DOCKER=1 — корневой .env не перезаписывает подключение к БД внутри контейнера.
# Открыть их порты на хосте (отладка): docker compose -f docker-compose.yml -f docker-compose.publish-internal-ports.yml up -d
#
#POSTGRES_USER=gigaboard
#POSTGRES_PASSWORD=gigaboard_secret
#POSTGRES_DB=gigaboard
#FRONTEND_PORT=3000
#FRONTEND_DEV_PORT=5173
# Сборка frontend: оставьте пустым для одного origin с nginx (рекомендуется в Docker)
#VITE_API_URL=
# Сборка backend: если из Docker VM недоступен pypi.org — зеркало для build-arg
#PYPI_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# 1 — не выполнять alembic upgrade при старте backend-контейнера
#SKIP_ALEMBIC_UPGRADE=0

# ============================================
# Frontend (Vite) — файл apps/web/.env или apps/web/.env.local
# ============================================
# Не задано / пусто — в браузере SPA axios и Socket.IO всегда используют window.location.origin
# (тот же хост/порт, что у UI: Vite proxy в dev, nginx в Docker). VITE_API_URL не задаёт другой origin в браузере.
# Оставьте для редких сценариев без window или документации; не полагайтесь на прямой :8000 из UI.
#VITE_API_URL=http://localhost:8000
#
# Только dev: прокси Vite → backend (vite.config.ts). docker-compose.dev: http://backend:8000
# Локальный Vite + полный стек Docker только с FRONTEND_PORT (без :8000 на хосте):
#VITE_DEV_PROXY_TARGET=http://localhost:3000
# Или: .\run-frontend.ps1 -DockerNginx (подставит :3000; при другом порте задайте переменную вручную)
